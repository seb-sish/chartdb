CHARTDB_DOMAIN=chartdb.example.com

# Must be the Docker network where the Traefik container is attached.
CHARTDB_PROXY_NETWORK=chartdb-proxy

# Generate a value with:
# docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'replace-this-password'
# Paste the full output, for example: admin:$2y$...
# In .env, every $ in the hash must be escaped as $$ for Docker Compose.
CHARTDB_BASIC_AUTH_USERS=PASTE_HTPASSWD_OUTPUT_HERE
